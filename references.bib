@article{clegg_chemical-model_1995,
  abstract = {The calculation of the percentage of un-ionised ammonia in estuarine water and seawater requires values of the stoichiometric dissociation constant of ammonia, defined by: K-a\ast /mol kg(-1) = mNH(3)mH(+)/mMH(4)(+), where m denotes molality. A thermodynamic model of seawater, including dissolved NH3 and NH4+, is developed using an extended Pitzer formalism parameterised from available data. The model is validated using emf measurements for cells containing artificial seawater with added HCl, and NH4Cl, and NH3 over a range of temperatures and salinities. Calculated values of K-a\ast  are tabulated from 0 to 40 ppt salinity and -2 to 40 degrees C, on both a free (mH(+)) and total (mH(+) + mHSO(4)(-)) hydrogen ion basis for use with pH measurements made on the corresponding scales. Accuracy (in K-a\ast ) is likely to be better than 5\textbackslash \% at all temperatures and salinities.},
  annote = {A very good paper. I learned a lot from it for my PhD work.
2403. Calculated dissociation constant from Bates and Pinchin (1949) data. Heat capacity change very small, so they seem to use the van\textquotesingle t Hoff equation.},
  author = {Clegg, S. L. and Whitfield, M.},
  issn = {0016-7037},
  journal = {Geochimica et Cosmochimica Acta},
  keywords = {NH3 model paper, Citric acid paper},
  number = {12},
  pages = {2403--2421},
  title = {A chemical-model of seawater including dissolved ammonia and the stoichiometric dissociation-constant of ammonia in estuarine water and seawater from -2C to 40C},
  volume = {59},
  year = {1995},
}



@article{dalby_mechanistic_2021,
  abstract = {Liquid manure (slurry) from livestock releases methane (CH4) that contributes significantly to global warming. Existing models for slurry CH4 production\textemdash used for mitigation and inventories\textemdash include effects of organic matter loading, temperature, and retention time but cannot predict important effects of management, or adequately capture essential temperature-driven dynamics. Here we present a new model that includes multiple methanogenic groups whose relative abundance shifts in response to changes in temperature or other environmental conditions. By default, the temperature responses of five groups correspond to those of four methanogenic species and one uncultured methanogen, although any number of groups could be defined. We argue that this simple mechanistic approach is able to describe both short- and long-term responses to temperature where other existing approaches fall short. The model is available in the open-source R package ABM (https://github.com/sashahafner/ABM) as a single flexible function that can include effects of slurry management (e.g., removal frequency and treatment methods) and changes in environmental conditions over time. Model simulations suggest that the reduction of CH4 emission by frequent emptying of slurry pits is due to washout of active methanogens. Application of the model to represent a full-scale slurry storage tank showed it can reproduce important trends, including a delayed response to temperature changes. However, the magnitude of predicted emission is uncertain, primarily as a result of sensitivity to the hydrolysis rate constant, due to a wide range in reported values. Results indicated that with additional work\textemdash particularly on the magnitude of hydrolysis rate\textemdash the model could be a tool for estimation of CH4 emissions for inventories.},
  author = {Dalby, Frederik R. and Hafner, Sasha D. and Petersen, S{\o}ren O. and Vanderzaag, Andrew and Habtewold, Jemaneh and Dunfield, Kari and Chantigny, Martin H. and Sommer, Sven G.},
  doi = {10.1371/journal.pone.0252881},
  issn = {1932-6203},
  journal = {PLOS ONE},
  keywords = {STM paper},
  language = {en},
  month = {June},
  note = {Publisher: Public Library of Science},
  number = {6},
  pages = {e0252881},
  title = {A mechanistic model of methane emission from animal slurry with a focus on microbial groups},
  url = {https://journals.plos.org/plosone/article?id=10.1371/journal.pone.0252881},
  urldate = {2021-07-30},
  volume = {16},
  year = {2021},
}


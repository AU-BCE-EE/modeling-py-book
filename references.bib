@article{sommer_algorithms_2004,
  abstract = {Biogenic emissions of methane (CH4) and nitrous oxide (N2O) from animal manure are stimulated by the degradation of volatile solids (VS) which serves as an energy source and a sink for atmospheric oxygen. Algorithms are presented which link carbon and nitrogen turnover in a dynamic prediction of CH4 and N2O emissions during handling and use of liquid manure (slurry). A sub-model for CH4 emissions during storage relates CH4 emissions to VS, temperature and storage time, and estimates the reduction in VS. A second sub-model estimates N2O emissions from field-applied slurry as a function of VS, slurry N and soil water potential, but emissions are estimated using emission factors. The model indicated that daily flushing of slurry from cattle houses would reduce total annual CH4+N2O emissions by 35\textbackslash \% (CO2 eq.), and that cooling of pig slurry in-house would reduce total annual CH4+N2O emissions by 21\textbackslash \% (CO2 eq.). Anaerobic digestion of slurry and organic waste produces CH4 at the expense of VS. Accordingly, the model predicted a 90\textbackslash \% reduction of CH4 emissions from outside stores with digested slurry, and a {\textbackslash textgreater}50\textbackslash \% reduction of N2O emissions after spring application of digested as opposed to untreated slurry. The sensitivity of the model towards storage temperature and soil water potential was examined. This study indicates that simple algorithms to account for ambient climatic conditions may significantly improve the prediction of CH4 and N2O emissions from animal manure.},
  annote = {At least for the methane production component: a typical poorly-done study.
145. This appears to be the equation for calculating methane emission rate:
F(T) = VS(d)\ast b(1)\ast exp(lnA - E\ast (1/RT)) + . . .
This appears to be all. . . there seems to be no mass balance for VS!
146. There is a Table 2 that at least includes a factor to go from VS to CH4, so perhaps a mass balance was included in the model. I suspect that Al did not include this in IFSM.
},
  author = {Sommer, SG and Petersen, SO and Moller, HB},
  issn = {1385-1314},
  journal = {NUTRIENT CYCLING IN AGROECOSYSTEMS},
  keywords = {Anaerobic digestion, Methane emissions},
  month = {June},
  number = {2},
  pages = {143--154},
  title = {Algorithms for calculating methane and nitrous oxide emissions from manure management},
  url = {http://apps.isiknowledge.com/full_record.do?product=WOS&search_mode=GeneralSearch&qid=1&SID=4AhaBilB7LckJ@DPFGj&page=1&doc=1},
  urldate = {2009-10-13},
  volume = {69},
  year = {2004},
}


grp_pars$grps <- grps
grp_pars$xa_fresh <- xa_fresh
grp_pars$T_min <- T_min
grp_pars$T_max <- T_max
grp_pars$T_opt <- T_opt
grp_pars$xa_init <- xa_init
out <- abm(365, grp_pars = grp_pars)
setDT(out)
long <- melt(out, measure.vars = c('m1_conc','m2_conc'))
ggplot(long, aes(time, value, col = variable)) + geom_point()
ggplot(long, aes(time, CH4_emis_rate))
ggplot(long, aes(time, CH4_emis_rate)) + geom_point()
out <- abm(365, grp_pars = grp_pars, add_pars = list(resid_enrich = 0))
setDT(out)
long <- melt(out, measure.vars = c('m1_conc','m2_conc'))
ggplot(long, aes(time, value, col = variable)) + geom_point()
ggplot(long, aes(time, CH4_emis_rate)) + geom_point()
ggplot(long, aes(time, value, col = variable)) + geom_point()
ggplot(long, aes(time, CH4_emis_rate)) + geom_point()
out <- abm(3*365, grp_pars = grp_pars, add_pars = list(resid_enrich = 0))
setDT(out)
long <- melt(out, measure.vars = c('m1_conc','m2_conc'))
ggplot(long, aes(time, value, col = variable)) + geom_point()
ggplot(long, aes(time, CH4_emis_rate)) + geom_point()
ggplot(long, aes(time, CH4_emis_rate/slurry_mass)) + geom_point()
ggplot(long, aes(time, value, col = variable)) + geom_point()

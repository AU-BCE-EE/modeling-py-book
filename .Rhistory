library(tidyr)
data <- data %>%
select(
Pig_category, Method, Diet,
Feces = C_Feces,
Urin = C_Urin,
Metan = C_Metan,
Exhalation = C_Exhalation,
Retention = C_Retention
) %>%
pivot_longer(
cols = Feces:Retention,
names_to = "C_component",
values_to = "value"
) %>%
mutate(
C_component = factor(
C_component,
levels = c("Feces", "Urin", "Metan", "Exhalation", "Retention")
),
Method = factor(Method, levels = c("Analyzed", "Predicted"))
)
ggplot(data, aes(x = Method, y = value, fill = C_component)) +
geom_bar(
stat = "identity",
width = 0.65,
color = "grey20",     # subtle bar borders
linewidth = 0.2
) +
# Reference line at zero (important for retention interpretation)
geom_hline(yintercept = 0, color = "grey40", linewidth = 0.4) +
scale_fill_manual(
values = c(
"Feces"       = "#6baed6",
"Urin"        = "#c6dbef",
"Metan"       = "#9ecae1",
"Exhalation"  = "#deebf7",
"Retention"   = "#08519c"
),
labels = c(
"Feces",
"Urine",
"Methane",
"Exhalation",
"Retention"
)
) +
facet_grid(
Pig_category ~ Diet,
scales = "fixed",     # crucial for comparison
switch = "y"
) +
labs(
x = NULL,
y = expression("Carbon balance (g C animal"^{-1}~d^{-1}*")"),
fill = "C component"
) +
theme_classic(base_size = 14) +
theme(
legend.position = "top",
legend.key.width = unit(1.3, "cm"),
strip.background = element_blank(),
strip.text = element_text(face = "bold", size = 12),
axis.text.x = element_text(face = "bold"),
axis.title.y = element_text(face = "bold"),
panel.spacing = unit(1.2, "lines")
)

library(readxl)
library(ggplot2)
library(lmerTest)
data <- data.frame(
Pig_category = rep(c("Grower-finisher pigs", "Gestating sows"), each = 6),
Diet = rep(c("CON", "WB", "SBP"), times = 4),
Method = rep(c("Predicted", "Analyzed"), each = 3, times = 2),
C_intake = c(
697, 699, 725,   # Grower-finisher – Predicted
686, 703, 689,   # Grower-finisher – Analyzed
716, 791, 720,   # Gestating sows – Predicted
732, 813, 723    # Gestating sows – Analyzed
),
C_Feces = c(
110, 180, 130,   # Grower-finisher – Predicted
133, 215, 158,   # Grower-finisher – Analyzed
95, 175, 102,   # Gestating sows – Predicted
108, 213, 130    # Gestating sows – Analyzed
),
C_Urin = c(
14, 15, 14,   # Grower-finisher – Predicted
16, 20, 16,   # Grower-finisher – Analyzed
10, 13, 10,   # Gestating sows – Predicted
18, 20, 18    # Gestating sows – Analyzed
),
C_Metan = c(
1.37, 1.26, 3.5,   # Grower-finisher – Predicted
1.45, 1.66, 2.59,   # Grower-finisher – Analyzed
2.0, 2.7, 3.9,   # Gestating sows – Predicted
2.6, 3.3, 5.0    # Gestating sows – Analyzed
),
C_Exhalation = c(
365, 372, 372,   # Grower-finisher – Predicted
378, 360, 380,   # Grower-finisher – Analyzed
609, 609, 609,   # Gestating sows – Predicted
564, 569, 564    # Gestating sows – Analyzed
),
C_Retention = c(
207, 131, 206,   # Grower-finisher – Predicted
158, 107, 132,   # Grower-finisher – Analyzed
0.05, -8.7, -4.9,   # Gestating sows – Predicted
39.4, 7.7, 6.0   # Gestating sows – Analyzed
))
View(data)
data <- data %>%
select(
Pig_category, Method, Diet,
Feces = C_Feces,
Urin = C_Urin,
Metan = C_Metan,
Exhalation = C_Exhalation,
Retention = C_Retention
) %>%
pivot_longer(
cols = Feces:Retention,
names_to = "C_component",
values_to = "value"
) %>%
mutate(
C_component = factor(
C_component,
levels = c("Feces", "Urin", "Metan", "Exhalation", "Retention")
),
Method = factor(Method, levels = c("Analyzed", "Predicted"))
)
